# ─── Gemini LLM ──────────────────────────────────────────────────────────────
# Required for LLM enrichment and structured extraction.
# Get a FREE key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model to use. Recommended: gemini-3.5-flash (best free-tier availability)
# Other options: gemini-2.0-flash, gemini-3.1-flash
GEMINI_MODEL=gemini-3.5-flash

# ─── Embeddings ──────────────────────────────────────────────────────────────
# "sentence_transformers" = local, free, uses all-MiniLM-L6-v2 (recommended)
# "gemini"               = uses Google text-embedding-004 (requires GEMINI_API_KEY)
EMBEDDING_PROVIDER=sentence_transformers

# Local sentence-transformers model (only used when EMBEDDING_PROVIDER=sentence_transformers)
ST_MODEL=all-MiniLM-L6-v2

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Your MongoDB connection string.
# Free cluster: https://cloud.mongodb.com → Create Free Cluster → Connect
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/
# NOTE: If your password contains '@', encode it as '%40'
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/

# MongoDB database name (created automatically if it doesn't exist)
MONGODB_DB=candidate_platform

# ─── GitHub (optional) ───────────────────────────────────────────────────────
# Personal access token for higher GitHub API rate limits.
# Only needed if you use the GitHub profile parser feature.
# GITHUB_TOKEN=your_github_token_here
